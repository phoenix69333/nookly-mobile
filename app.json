{
  "expo": {
    "name": "Nookly",
    "slug": "Nookly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nookly",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shon1123.Nookly",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.shon1123.Nookly",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
"plugins": [
  [
    "expo-notifications",
    {
      "sounds": [
        "./assets/sounds/notification.wav"
      ]
    }
  ],
  [
    "expo-media-library",
    {
      "photosPermission": "Allow Nookly to save property photos and videos to your device.",
      "savePhotosPermission": "Allow Nookly to save property photos and videos to your device.",
      "isAccessMediaLocationEnabled": true
    }
  ],
  "expo-router",
  [
    "expo-splash-screen",
    {
      "image": "./assets/images/icon.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE",
      "dark": {
        "backgroundColor": "#000000"
      }
    }
  ],
  "expo-secure-store",
  "@react-native-community/datetimepicker",
  "expo-font",
  "expo-web-browser",
  "expo-video"
],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "794b1644-79da-4c3e-92d2-d3605b2c208a"
      }
    },
    "owner": "phoenix69"
  }
}
